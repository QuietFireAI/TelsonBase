# =============================================================================
# TelsonBase v8.0.2B — Environment Configuration Template
# =============================================================================
# Copy this file to .env and update values for your deployment.
# Sensitive secrets should go in ./secrets/ (Docker secrets, not env vars).
# Run scripts/generate_secrets.sh to bootstrap the secrets directory.
# =============================================================================

# --- Environment Mode ---
# Set to "production" to enable strict secrets validation
TELSONBASE_ENV=development

# --- API Key ---
# Auto-populated by scripts/generate_secrets.sh — do not edit manually.
MCP_API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# --- JWT ---
# Auto-populated by scripts/generate_secrets.sh — do not edit manually.
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# --- Database ---
# Auto-populated by scripts/generate_secrets.sh — do not edit manually.
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
DATABASE_URL=postgresql://telsonbase:CHANGE_ME_IN_PRODUCTION@postgres:5432/telsonbase

# --- Redis ---
# Auto-populated by scripts/generate_secrets.sh — do not edit manually.
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION
REDIS_URL=redis://redis:6379/0

# --- MQTT (Mosquitto) ---
MOSQUITTO_HOST=mosquitto
MOSQUITTO_PORT=1883
MOSQUITTO_USER=telsonbase
# Auto-populated by scripts/generate_secrets.sh — do not edit manually.
MOSQUITTO_PASSWORD=CHANGE_ME_IN_PRODUCTION

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434

# --- Traefik ---
# Set to your domain in production (e.g., telsonbase.example.com)
TRAEFIK_DOMAIN=localhost
TRAEFIK_ACME_EMAIL=your-email@example.com

# --- Grafana ---
GRAFANA_ADMIN_USER=admin

# --- Open WebUI ---
# Auto-populated by scripts/generate_secrets.sh — do not edit manually.
WEBUI_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=300
RATE_LIMIT_BURST=60

# --- Email / SMTP ---
# Dev: leave SMTP_HOST=mailhog to catch all mail at http://localhost:8025 (no real emails sent)
# Prod: set to your real SMTP provider (Gmail, Outlook, Resend, SendGrid, etc.)
#   Gmail:   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  (requires App Password)
#   Outlook: SMTP_HOST=smtp.office365.com  SMTP_PORT=587
#   Resend:  SMTP_HOST=smtp.resend.com  SMTP_PORT=465  SMTP_USER=resend  SMTP_PASSWORD=<api-key>
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
APP_BASE_URL=http://localhost:8000

# --- Logging ---
LOG_LEVEL=INFO

# --- Identiclaw DID Identity Integration ---
# Master switch: set to true to enable DID-based agent authentication
IDENTICLAW_ENABLED=false
IDENTICLAW_REGISTRY_URL=https://identity.identiclaw.com
IDENTICLAW_DID_CACHE_TTL_HOURS=24
IDENTICLAW_VC_CACHE_TTL_HOURS=12
IDENTICLAW_KNOWN_ISSUERS=["did:web:identiclaw.com"]

# --- OpenClaw Governance Integration (v7.4.0CC) ---
# Master switch: set to true to enable "Control Your Claw" governance proxy
OPENCLAW_ENABLED=false
OPENCLAW_DEFAULT_TRUST=quarantine
OPENCLAW_AUTO_DEMOTE_THRESHOLD=0.50
OPENCLAW_MAX_INSTANCES=10
OPENCLAW_ACTION_LOG_TTL_HOURS=24
