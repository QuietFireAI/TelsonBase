# ============================================================================
# TelsonBase v11.0.1 — .gitignore
# ============================================================================

# Claude Code context files (session history, plans, local AI config)
CLAUDE.md
CLAUDE.local.md
.claude/

# Pre-drop staging folder (internal artifacts, not for public repo)
Dont_drop/

# Test output files (generated by Tee-Object during test runs)
last_test_run.txt
scout_results.txt
payload*.json

# Environment and secrets (NEVER commit real credentials)
.env
.env.local
.env.production
secrets/
monitoring/mosquitto/password_file

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath

# OS
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Backups (entire directory — binary artifacts and snapshots)
backups/

# Raw recordings (converted GIFs are committed; source recordings stay local)
screenshots/*.mp4
screenshots/*.mov

# Brand/social assets (uploaded to GitHub Settings directly, not tracked in repo)
screenshots/QF*
screenshots/brand*

# Internal operations docs — not for public repo
docs/Operation Documents/COMPETITIVE_POSITIONING.md
docs/Operation Documents/PRICING_MODEL.md
docs/LAUNCH_SOCIAL_CHECKLIST.md
docs/GIF_RECORDING_GUIDE.md
docs/GIF_VOICEOVER_SCRIPT.md
docs/DEMO_SCRIPT_agent_registration.md
docs/DEMO_WALKTHROUGH_step_by_step.md
docs/Testing Documents/PRE_DROP_AUDIT.md
docs/IDENTICLAW_OPERATIONS.md

# Website (served separately — not part of the GitHub repo)
website/
website-demo/
website-quietfire/

# Session artifact text files in docs
docs/*.txt

# Test artifacts
token_response.json
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# Docker (local overrides)
docker-compose.override.yml

# Logs
*.log
logs/

# Node (if any frontend tooling added later)
node_modules/
package-lock.json

# Jupyter
.ipynb_checkpoints/

# mypy / type checking
.mypy_cache/
.dmypy.json
