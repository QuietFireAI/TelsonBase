# ============================================================================
# TelsonBase v8.0.2 — .gitignore
# ============================================================================

# Claude Code context files (session history, plans, local AI config)
CLAUDE.md
CLAUDE.local.md
.claude/

# Pre-drop staging folder (internal artifacts, not for public repo)
Dont_drop/

# Test output files (generated by Tee-Object during test runs)
last_test_run.txt
scout_results.txt
payload*.json

# Environment and secrets (NEVER commit real credentials)
.env
.env.local
.env.production
secrets/
monitoring/mosquitto/password_file

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath

# OS
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Backups (binary artifacts)
backups/*.tar
backups/*.tar.gz
backups/*.zip
backups/*.bak

# Test artifacts
token_response.json
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# Docker (local overrides)
docker-compose.override.yml

# Logs
*.log
logs/

# Node (if any frontend tooling added later)
node_modules/
package-lock.json

# Jupyter
.ipynb_checkpoints/

# mypy / type checking
.mypy_cache/
.dmypy.json
