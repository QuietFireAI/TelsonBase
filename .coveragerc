[run]
relative_files = True
include =
    core/*
    api/*
    agents/*
    toolroom/*
omit =
    core/mqtt_bus.py
    core/ollama_service.py
    agents/ollama_agent.py

[report]
ignore_errors = True
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.
    pass
    raise ImportError
